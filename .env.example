# Supabase — get these from https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# OpenAI — get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Lemon Squeezy — get from https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=your-lemonsqueezy-api-key-here

# Lemon Squeezy Webhook Secret — set when creating a webhook in LS dashboard
# Dashboard → Settings → Webhooks → Add webhook → copy the Signing Secret
LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-signing-secret-here

# Lemon Squeezy Store ID — Dashboard → Settings → Stores → your store ID (number)
LEMONSQUEEZY_STORE_ID=12345

# Lemon Squeezy Variant IDs — create products in LS dashboard
# Dashboard → Products → create "VisaLetter Basic" ($9/mo) → copy Variant ID
LEMONSQUEEZY_BASIC_VARIANT_ID=67890
# Dashboard → Products → create "VisaLetter Pro" ($19/mo) → copy Variant ID
LEMONSQUEEZY_PRO_VARIANT_ID=67891

# Your site URL — use http://localhost:3000 for local dev
NEXT_PUBLIC_SITE_URL=http://localhost:3000
